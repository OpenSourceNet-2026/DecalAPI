# DecalAPI — API key configuration
# Copy this file to .env and fill in your keys.
# The Settings page inside the app can also write .env for you.

# Required — get yours at virustotal.com → Profile → API Key
VT_API_KEY=""

# Optional — bazaar.abuse.ch → Account → API key
MB_API_KEY=""

# Optional — requires an any.run Hunter plan or higher
ANYRUN_API_KEY=""
